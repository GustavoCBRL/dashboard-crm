DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
PGSSLMODE=disable
CIDADES=Aracaju,Salvador,Brasília,Camaçari,Recife
PORT=3000

# Opcional: sincronização com Google Sheets
SPREADSHEET_ID=
GOOGLE_CREDENTIALS=./credencial-google.json
# Em produção/Railway, prefira colar o JSON inteiro em uma variável secreta:
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
